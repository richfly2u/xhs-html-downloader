PORT=8787
CORS_ORIGIN=*
REQUEST_TIMEOUT_MS=20000
MAX_HTML_BYTES=4194304
NODE_ENV=development

# Groq is preferred when both keys exist.
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo

# Optional OpenAI fallback.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

AI_TRANSCRIBE_VIDEO=true
TRANSCRIBE_LANGUAGE=zh
MAX_TRANSCRIBE_BYTES=25165824
AI_TIMEOUT_MS=55000
AI_MEDIA_TIMEOUT_MS=45000

# Optional thumbnail proxy limits.
THUMBNAIL_TIMEOUT_MS=15000
MAX_THUMBNAIL_BYTES=3670016
